# Copy to .env.local in the REPO ROOT (next to package.json). Vite does not load env from src/.
# GitHub Actions: add the same keys as repository secrets for the Pages workflow.

VITE_SUPABASE_URL=https://YOUR_PROJECT_REF.supabase.co
VITE_SUPABASE_ANON_KEY=your_anon_key

# Optional: simulate GitHub Pages base path locally, e.g. VITE_BASE_PATH=/musing/
